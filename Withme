  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script>
    // Initialize Supabase
    const { createClient } = supabase;
    const supabaseUrl = 'https://ehkxbyrdurlxecjfudrn.supabase.co';
    const supabaseKey = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVoa3hieXJkdXJseGVjamZ1ZHJuIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzkwMjQ0MTUsImV4cCI6MjA5NDYwMDQxNX0.41EHIvfrAX46QcjzHB121PPpT573KAvem4A6BUGr-WQ';
    const supabaseClient = createClient(supabaseUrl, supabaseKey);

    function openModal(companionName = '') {
      document.getElementById('modal').classList.add('open');
      document.body.style.overflow = 'hidden';

      const title = document.querySelector('#modal h2');
      const subtitle = document.getElementById('modal-subtitle');
      document.getElementById('requested-companion').value = companionName;

      if (companionName) {
        title.textContent = `Book ${companionName}`;
        subtitle.textContent = `Fill in your details below to request a session with ${companionName}.`;
      } else {
        title.textContent = `Book a Human`;
        subtitle.textContent = `Fill in a few details and we'll match you with the perfect companion.`;
      }
    }

    function closeModal() {
      document.getElementById('modal').classList.remove('open');
      document.body.style.overflow = '';
    }

    function closeModalOutside(e) {
      if (e.target === document.getElementById('modal')) closeModal();
    }

    // Companion Modal Logic
    function openCompanionModal() {
      document.getElementById('companion-modal').classList.add('open');
      document.body.style.overflow = 'hidden';
    }

    function closeCompanionModal() {
      document.getElementById('companion-modal').classList.remove('open');
      document.body.style.overflow = '';
    }

    function closeCompanionModalOutside(e) {
      if (e.target === document.getElementById('companion-modal')) closeCompanionModal();
    }

    async function handleBooking(event) {
      if (event) event.preventDefault();

      const fileInput = document.getElementById('id-upload');
      const name = document.getElementById('book-name').value;
      let phone = document.getElementById('book-phone').value;
      const date = document.getElementById('book-date').value;
      const time = document.getElementById('book-time').value;

      if (!name || !phone || !date || !time) {
        alert("Please fill in your Name, WhatsApp Number, Date, and Time.");
        return;
      }

      if (!fileInput || !fileInput.files.length) {
        alert("Safety First! 🛡️\n\nPlease upload a valid Government ID to verify your identity before booking a companion.");
        return;
      }

      if (supabaseKey === 'YOUR_SUPABASE_ANON_KEY_HERE') {
        alert("Please add your Supabase Anon Key to the code first!");
        return;
      }

      const btn = document.querySelector('.btn-submit');
      btn.textContent = 'Securely Uploading ID... ✨';
      btn.disabled = true;

      try {
        const file = fileInput.files[0];
        const fileExt = file.name.split('.').pop();
        const fileName = `${Date.now()}-${Math.random().toString(36).substring(7)}.${fileExt}`;

        // 1. Upload ID to Supabase Storage
        const { data: uploadData, error: uploadError } = await supabaseClient.storage
          .from('id_documents')
          .upload(fileName, file);

        if (uploadError) throw uploadError;

        // Get public URL for the uploaded ID
        const { data: { publicUrl } } = supabaseClient.storage
          .from('id_documents')
          .getPublicUrl(fileName);

        btn.textContent = 'Saving Booking Details... 🔄';

        // Format the phone number into a WhatsApp clickable link
        const cleanPhone = phone.replace(/[^0-9]/g, '');
        const message = encodeURIComponent("Hello! Your companion slot for WithMe is confirmed.");
        const whatsappLink = `https://wa.me/${cleanPhone}?text=${message}`;

        // Add requested companion to notes
        let finalNotes = document.getElementById('book-notes').value;
        const requestedCompanion = document.getElementById('requested-companion').value;
        if (requestedCompanion) {
          finalNotes = `[REQUESTED COMPANION: ${requestedCompanion}] - ` + finalNotes;
        }

        // 2. Save Booking to Database
        const bookingData = {
          name: name,
          phone: whatsappLink, // Saves as a clickable WhatsApp link!
          city: document.getElementById('book-city').value,
          activity: document.getElementById('book-activity').value,
          date: date,
          time: time,
          duration: document.getElementById('book-duration').value,
          notes: finalNotes,
          id_url: publicUrl,
          status: 'Pending Verification'
        };

        const { error: dbError } = await supabaseClient
          .from('bookings')
          .insert([bookingData]);

        if (dbError) throw dbError;

        btn.textContent = 'Request Sent! Pending Approval 🛡️';
        btn.style.background = '#16a34a';
        setTimeout(closeModal, 3000);

      } catch (error) {
        alert("Error: " + error.message);
        console.error(error);
        btn.textContent = 'Find My Companion →';
        btn.disabled = false;
      }
    }

    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') closeModal();
    });
    async function handleCompanionApply(event) {
      if (event) event.preventDefault();

      const idInput = document.getElementById('comp-id-upload');
      const dlInput = document.getElementById('comp-dl-upload');
      const photoInput = document.getElementById('comp-photo-upload');
      const name = document.getElementById('comp-name').value;
      const phone = document.getElementById('comp-phone').value;

      if (!name || !phone) {
        alert("Please fill in your Name and WhatsApp Number.");
        return;
      }
      if (!photoInput || !photoInput.files.length) {
        alert("Please upload a beautiful Profile Photo to attract customers!");
        return;
      }
      if (!idInput.files.length && !dlInput.files.length) {
        alert("Safety First! 🛡️\n\nPlease upload at least one valid Government ID (Aadhaar or Driving Licence) for your background check.");
        return;
      }

      const btn = document.querySelector('#companion-modal .btn-submit');
      btn.textContent = 'Securely Uploading ID... ✨';
      btn.disabled = true;

      try {
        const uploads = [];
        let idUrl = null;
        let photoUrl = null;
        let dlUrl = null;

        // 1. Queue Photo Upload
        const photoFile = photoInput.files[0];
        const photoExt = photoFile.name.split('.').pop();
        const photoName = `comp-photo-${Date.now()}-${Math.random().toString(36).substring(7)}.${photoExt}`;
        uploads.push(supabaseClient.storage.from('id_documents').upload(photoName, photoFile));

        // 2. Queue Aadhaar Upload (if provided)
        let idName = null;
        if (idInput.files.length > 0) {
          const idFile = idInput.files[0];
          const idExt = idFile.name.split('.').pop();
          idName = `comp-id-${Date.now()}-${Math.random().toString(36).substring(7)}.${idExt}`;
          uploads.push(supabaseClient.storage.from('id_documents').upload(idName, idFile));
        }

        // 3. Queue DL Upload (if provided)
        let dlName = null;
        if (dlInput.files.length > 0) {
          const dlFile = dlInput.files[0];
          const dlExt = dlFile.name.split('.').pop();
          dlName = `comp-dl-${Date.now()}-${Math.random().toString(36).substring(7)}.${dlExt}`;
          uploads.push(supabaseClient.storage.from('id_documents').upload(dlName, dlFile));
        }

        // Run all uploads simultaneously!
        const results = await Promise.all(uploads);

        // Check for any upload errors
        for (let result of results) {
          if (result.error) throw result.error;
        }

        // Get public URLs
        photoUrl = supabaseClient.storage.from('id_documents').getPublicUrl(photoName).data.publicUrl;
        if (idName) idUrl = supabaseClient.storage.from('id_documents').getPublicUrl(idName).data.publicUrl;
        if (dlName) dlUrl = supabaseClient.storage.from('id_documents').getPublicUrl(dlName).data.publicUrl;

        btn.textContent = 'Submitting Application... 🔄';

        const cleanPhone = phone.replace(/[^0-9]/g, '');
        const message = encodeURIComponent(`Hello ${name}! We received your application to become a WithMe Companion. Let's schedule a quick video call!`);
        const whatsappLink = `https://wa.me/${cleanPhone}?text=${message}`;

        const appData = {
          name: name,
          phone: whatsappLink,
          city: document.getElementById('comp-city').value,
          demographics: document.getElementById('comp-demographics').value,
          occupation: document.getElementById('comp-occupation').value,
          hobbies: document.getElementById('comp-hobbies').value,
          interests: document.getElementById('comp-interests').value,
          id_url: idUrl,
          dl_url: dlUrl,
          photo_url: photoUrl,
          status: 'Pending Review'
        };

        const { error: dbError } = await supabaseClient
          .from('applications')
          .insert([appData]);

        if (dbError) throw dbError;

        btn.textContent = 'Application Received! 🎉';
        btn.style.background = '#16a34a';
        setTimeout(closeCompanionModal, 3000);

      } catch (error) {
        alert("Error: " + error.message);
        console.error(error);
        btn.textContent = 'Submit Application →';
        btn.disabled = false;
      }
    }
  </script>
